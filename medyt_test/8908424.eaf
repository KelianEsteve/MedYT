        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a299"
                TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
                <ANNOTATION_VALUE>remember the following key points number one most retained bullets stay retained</ANNOTATION_VALUE>
