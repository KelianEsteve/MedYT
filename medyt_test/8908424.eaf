        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a300"
                TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
                <ANNOTATION_VALUE>and most patients come back with issues related to that</ANNOTATION_VALUE>
