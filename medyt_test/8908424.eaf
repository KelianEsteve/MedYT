        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a298"
                TIME_SLOT_REF1="ts273" TIME_SLOT_REF2="ts274">
                <ANNOTATION_VALUE>so with that we’ll wrap up our conversation here on retained bullets</ANNOTATION_VALUE>
